# Inworld AI API Key (for serverless TTS endpoint)
# Format: username:password (will be Base64 encoded)
INWORLD_API_KEY=your_inworld_username:your_inworld_password

# Backend API URL
NEXT_PUBLIC_API_URL=https://voltvoice-backend.onrender.com

# ElevenLabs API Key (optional, if still using)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
